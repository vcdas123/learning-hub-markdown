{
  "name": "@learning-hub/markdown",
  "version": "0.1.0",
  "description": "Shared Markdown constants, prompts, slug helpers, and types for Learning Hub's frontend and backend. Phase 1: foundation only — no parser/validator logic yet.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
